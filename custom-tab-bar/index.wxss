.tab-bar-wrap {
  position: fixed;
  bottom: 36rpx;
  left: 48rpx;
  right: 48rpx;
  z-index: 999;
  pointer-events: none;
}

.tab-bar {
  display: flex;
  justify-content: space-around;
  align-items: center;
  height: 110rpx;
  background: rgba(255, 255, 255, 0.95);
  border-radius: 55rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.12);
  padding: 0 12rpx;
  pointer-events: auto;
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
}

.tab-item {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  height: 92rpx;
  border-radius: 46rpx;
  transition: all 0.25s ease;
}

.tab-item.active {
  background: rgba(104, 158, 132, 0.12);
}

.tab-text {
  font-size: 30rpx;
  color: #999999;
}

.tab-item.active .tab-text {
  color: #689e84;
  font-weight: 600;
}
