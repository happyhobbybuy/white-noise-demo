<view class="tab-bar-wrap">
  <view class="tab-bar">
    <view
      class="tab-item {{selected === index ? 'active' : ''}}"
      wx:for="{{list}}"
      wx:key="pagePath"
      data-index="{{index}}"
      bindtap="onSwitch"
    >
      <view class="tab-text">{{item.text}}</view>
    </view>
  </view>
</view>
