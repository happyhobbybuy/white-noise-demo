<view class="page-container">
  <view class="base-bg"></view>
  <!-- 播放时全屏实景背景 -->
  <image class="play-bg {{bgUrl ? 'active' : ''}}" src="{{bgUrl}}" mode="aspectFill"></image>
  <!-- 毛玻璃遮罩层 -->
  <view class="blur-overlay {{bgUrl ? 'active' : ''}}"></view>

  <view class="top-bar" style="position: fixed; top: 0; left: 0; right: 0; z-index: 100; height: {{menuButtonTop + menuButtonHeight}}px;">
    <view class="page-title" style="padding-top: {{menuButtonTop}}px; height: {{menuButtonHeight}}px;">专注钟</view>
  </view>

  <view class="container" style="padding-top: {{menuButtonTop + menuButtonHeight + 10}}px;">
    <!-- 模式切换 -->
    <view class="mode-tabs">
      <view class="mode-tab {{mode === 'pomodoro' ? 'active' : ''}}" data-mode="pomodoro" bindtap="onModeSwitch">
        <text>🍅 番茄钟</text>
      </view>
      <view class="mode-tab {{mode === 'countdown' ? 'active' : ''}}" data-mode="countdown" bindtap="onModeSwitch">
        <text>⏳ 倒计时</text>
      </view>
      <view class="mode-tab {{mode === 'stopwatch' ? 'active' : ''}}" data-mode="stopwatch" bindtap="onModeSwitch">
        <text>⏱ 正计时</text>
      </view>
    </view>

    <!-- 圆环进度区域 -->
    <view class="progress-area">
      <canvas type="2d" id="progressCanvas" class="progress-canvas"></canvas>
      <view class="progress-text-area">
        <view class="time-display">{{timeDisplay}}</view>
        <view class="phase-label">{{phaseLabel}}</view>
        <view wx:if="{{mode === 'pomodoro'}}" class="round-info">第 {{currentRound}}/{{totalRounds}} 轮</view>
      </view>
    </view>

    <!-- 控制按钮 -->
    <view class="control-row">
      <view class="ctrl-btn" bindtap="onReset">
        <view class="ctrl-icon-wrap">
          <image class="ctrl-icon-img" src="/images/icon-reset.svg"></image>
        </view>
        <text class="ctrl-label">重置</text>
      </view>
      <view class="ctrl-btn main-ctrl" bindtap="onStartPause">
        <view class="ctrl-icon-wrap main">
          <image class="ctrl-icon-img" src="{{isRunning ? '/images/icon-pause.svg' : '/images/icon-play.svg'}}"></image>
        </view>
        <text class="ctrl-label">{{isRunning ? '暂停' : '开始'}}</text>
      </view>
      <view class="ctrl-btn" bindtap="onSkip">
        <view class="ctrl-icon-wrap">
          <image class="ctrl-icon-img" src="/images/icon-skip.svg"></image>
        </view>
        <text class="ctrl-label">跳过</text>
      </view>
    </view>

    <!-- 设置区域 -->
    <view class="settings-section">
      <view class="settings-header" bindtap="toggleSettings">
        <text class="settings-title">⚙️ 设置</text>
        <text class="settings-arrow">{{showSettings ? '▲' : '▼'}}</text>
      </view>
      
      <view class="settings-body" wx:if="{{showSettings}}">
        <!-- 专注时长 -->
        <view class="setting-group">
          <view class="setting-label">专注时长（分钟）</view>
          <view class="setting-options">
            <view 
              class="option-btn {{focusDuration === item ? 'active' : ''}}" 
              wx:for="{{durationOptions}}" 
              wx:key="*this"
              data-value="{{item}}"
              data-field="focusDuration"
              bindtap="onOptionTap"
            >{{item}}</view>
          </view>
        </view>

        <!-- 短休息 -->
        <view class="setting-group">
          <view class="setting-label">短休息（分钟）</view>
          <view class="setting-options">
            <view 
              class="option-btn {{shortBreak === item ? 'active' : ''}}" 
              wx:for="{{breakOptions}}" 
              wx:key="*this"
              data-value="{{item}}"
              data-field="shortBreak"
              bindtap="onOptionTap"
            >{{item}}</view>
          </view>
        </view>

        <!-- 长休息 -->
        <view class="setting-group">
          <view class="setting-label">长休息（分钟）</view>
          <view class="setting-options">
            <view 
              class="option-btn {{longBreak === item ? 'active' : ''}}" 
              wx:for="{{longBreakOptions}}" 
              wx:key="*this"
              data-value="{{item}}"
              data-field="longBreak"
              bindtap="onOptionTap"
            >{{item}}</view>
          </view>
        </view>

        <!-- 总轮次 -->
        <view class="setting-group">
          <view class="setting-label">总轮次</view>
          <view class="setting-options">
            <view 
              class="option-btn {{totalRounds === item ? 'active' : ''}}" 
              wx:for="{{roundOptions}}" 
              wx:key="*this"
              data-value="{{item}}"
              data-field="totalRounds"
              bindtap="onOptionTap"
            >{{item}}</view>
          </view>
        </view>
      </view>
    </view>

    <!-- 今日统计 -->
    <view class="stats-section">
      <view class="stats-title">📊 今日统计</view>
      <view class="stats-row">
        <view class="stat-item">
          <view class="stat-value">{{todayMinutes}}</view>
          <view class="stat-label">专注分钟</view>
        </view>
        <view class="stat-item">
          <view class="stat-value">{{todayRounds}}</view>
          <view class="stat-label">完成轮数</view>
        </view>
      </view>
    </view>

    <!-- 悬浮导航占位 -->
    <view class="tab-bar-placeholder"></view>
  </view>
</view>
