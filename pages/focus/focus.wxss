/* 专注钟页面样式 */
.page-container {
  position: relative;
  min-height: 100vh;
  overflow-x: hidden;
}

.container {
  padding: 0 32rpx;
  padding-bottom: 0;
  position: relative;
  display: flex;
  flex-direction: column;
}

.top-bar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
}

.page-title {
  position: absolute;
  left: 0;
  right: 0;
  text-align: center;
  font-size: 40rpx;
  font-weight: 700;
  color: #1a2530;
  white-space: nowrap;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

/* 模式切换 */
.mode-tabs {
  display: flex;
  gap: 16rpx;
  margin-bottom: 40rpx;
  justify-content: center;
}

.mode-tab {
  padding: 14rpx 28rpx;
  border-radius: 32rpx;
  font-size: 26rpx;
  font-weight: 600;
  color: #333;
  background: #ffffff;
  transition: all 0.3s;
}

.mode-tab.active {
  background: #689e84;
  color: #fff;
  box-shadow: 0 4rpx 12rpx rgba(104, 158, 132, 0.3);
}

/* 进度区域 */
.progress-area {
  position: relative;
  width: 420rpx;
  height: 420rpx;
  margin: 0 auto 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.progress-canvas {
  width: 420rpx;
  height: 420rpx;
}

.progress-text-area {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  text-align: center;
}

.time-display {
  font-size: 64rpx;
  font-weight: 700;
  color: #1a2530;
  letter-spacing: 2rpx;
  font-family: "Helvetica Neue", monospace;
}

.phase-label {
  font-size: 26rpx;
  color: #4a8a6a;
  margin-top: 8rpx;
  font-weight: 700;
}

.round-info {
  font-size: 24rpx;
  color: #555;
  margin-top: 8rpx;
  font-weight: 600;
}

/* 控制按钮 */
.control-row {
  display: flex;
  justify-content: center;
  align-items: flex-start;
  gap: 60rpx;
  margin: 0 0 40rpx;
  padding: 0 32rpx;
}

.ctrl-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
  width: 120rpx;
  flex-shrink: 0;
}

.ctrl-icon-wrap {
  width: 120rpx;
  height: 120rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.ctrl-icon-img {
  width: 52rpx;
  height: 52rpx;
}

.ctrl-icon-wrap.main {
  background: #689e84;
  border-radius: 50%;
  box-shadow: 0 6rpx 20rpx rgba(104, 158, 132, 0.35);
}

.ctrl-icon-wrap.main .ctrl-icon-img {
  width: 56rpx;
  height: 56rpx;
}

.ctrl-label {
  font-size: 22rpx;
  color: #333;
  font-weight: 600;
}

/* 设置区域 */
.settings-section {
  background: #ffffff;
  border-radius: 24rpx;
  margin-bottom: 24rpx;
  overflow: hidden;
}

.settings-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 32rpx;
}

.settings-title {
  font-size: 28rpx;
  color: #1a2530;
  font-weight: 700;
}

.settings-arrow {
  font-size: 24rpx;
  color: #666;
  font-weight: 600;
}

.settings-body {
  padding: 0 32rpx 24rpx;
}

.setting-group {
  margin-bottom: 24rpx;
}

.setting-label {
  font-size: 24rpx;
  color: #444;
  margin-bottom: 12rpx;
  font-weight: 600;
}

.setting-options {
  display: flex;
  gap: 16rpx;
  flex-wrap: wrap;
}

.option-btn {
  padding: 12rpx 28rpx;
  border-radius: 24rpx;
  font-size: 24rpx;
  font-weight: 600;
  color: #333;
  background: #ffffff;
  border: 2rpx solid #e0e0e0;
  transition: all 0.3s;
}

.option-btn.active {
  background: #689e84;
  color: #fff;
  border-color: #689e84;
}

/* 统计区域 */
.stats-section {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 24rpx 32rpx;
}

.stats-title {
  font-size: 28rpx;
  color: #1a2530;
  font-weight: 700;
  margin-bottom: 20rpx;
}

.stats-row {
  display: flex;
  gap: 40rpx;
}

.stat-item {
  text-align: center;
  flex: 1;
}

.stat-value {
  font-size: 44rpx;
  font-weight: 700;
  color: #4a8a6a;
}

.stat-label {
  font-size: 22rpx;
  color: #555;
  margin-top: 6rpx;
  font-weight: 600;
}
