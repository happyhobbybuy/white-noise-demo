/* 音效库页面样式 */
.page-container {
  position: relative;
  min-height: 100vh;
  overflow-x: hidden;
  display: flex;
  flex-direction: column;
}

.container {
  padding: 0 32rpx;
  padding-bottom: 0;
  position: relative;
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  box-sizing: border-box;
}

.top-bar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
}

.fixed-header {
  background: transparent;
}

.fixed-header-content {
  padding: 0 32rpx;
  padding-top: 16rpx;
}

.page-title {
  text-align: center;
  font-size: 40rpx;
  font-weight: 600;
  color: #2c3840;
  white-space: nowrap;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

/* 搜索栏 */
.search-bar {
  margin-bottom: 16rpx;
}

.search-input-wrap {
  display: flex;
  align-items: center;
  background: #ffffff;
  border-radius: 40rpx;
  padding: 16rpx 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.search-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}

.search-placeholder {
  color: #999;
}

.search-clear {
  font-size: 28rpx;
  color: #999;
  padding: 8rpx;
}

/* 分类标签 */
.category-scroll {
  margin-bottom: 32rpx;
  white-space: nowrap;
}

.category-list {
  display: flex;
  gap: 16rpx;
}

.category-tag {
  flex-shrink: 0;
  padding: 14rpx 32rpx;
  border-radius: 32rpx;
  font-size: 26rpx;
  color: #555;
  background: #ffffff;
  transition: all 0.3s;
}

.category-tag.active {
  background: #689e84;
  color: #fff;
  box-shadow: 0 4rpx 12rpx rgba(104, 158, 132, 0.3);
}

/* 音效网格 */
.sound-scroll {
  flex: 1;
  min-height: 0;
  width: 100%;
}

.sound-grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
  padding-bottom: 40rpx;
}

.sound-card {
  width: calc(50% - 12rpx);
  box-sizing: border-box;
  background: transparent;
  border-radius: 16rpx;
  padding: 0;
  text-align: center;
  transition: all 0.3s;
  border: 3rpx solid transparent;
  overflow: hidden;
  flex-shrink: 0;
  margin-bottom: 20rpx;
}

.sound-card.active {
  border-color: #689e84;
  box-shadow: 0 4rpx 16rpx rgba(104, 158, 132, 0.2);
}

.sound-cover-wrap {
  position: relative;
  width: 100%;
  height: 180rpx;
  border-radius: 16rpx;
  overflow: hidden;
  background: #ffffff;
}

.sound-cover {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.sound-icon {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 56rpx;
  background: #ffffff;
}

.sound-name-overlay {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 12rpx 16rpx;
  background: linear-gradient(transparent, rgba(0, 0, 0, 0.6));
  color: #fff;
  font-size: 26rpx;
  font-weight: 500;
  text-align: center;
}

/* 空结果 */
.empty-result {
  text-align: center;
  padding: 80rpx 0;
}

.empty-icon {
  font-size: 64rpx;
  display: block;
  margin-bottom: 16rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}

/* 底部占位，防止导航栏遮挡 */
.bottom-placeholder {
  height: 250rpx;
}
