<view class="page-container">
  <!-- 渐变动态背景 -->
  <view class="base-bg"></view>
  
  <!-- 播放时全屏实景背景 -->
  <image class="play-bg {{bgUrl ? 'active' : ''}}" src="{{bgUrl}}" mode="aspectFill"></image>
  <!-- 毛玻璃遮罩层 -->
  <view class="blur-overlay {{bgUrl ? 'active' : ''}}"></view>

  <view class="container" style="padding-top: {{statusBarHeight}}px;">
    <!-- 宣传语 -->
    <view class="desc-wrap">
      <view class="main-slogan">拾音</view>
    </view>

    <!-- 横向场景卡片 -->
    <scroll-view class="scene-scroll" scroll-x="true" enhanced="true" show-scrollbar="false">
      <view class="scene-list">
        <view 
          class="scene-card {{currentSceneId === item.id ? 'active' : ''}}" 
          wx:for="{{scenes}}" 
          wx:key="id" 
          data-index="{{index}}" 
          bindtap="onSceneTap"
        >
          <image class="scene-img" src="{{item.coverUrl}}" mode="aspectFill"></image>
          <view class="scene-mask">
            <view class="scene-title">{{item.name}}</view>
            <view class="scene-desc">{{item.desc}}</view>
          </view>
        </view>
      </view>
    </scroll-view>

    <!-- 播放器面板 -->
    <view class="player-wrap">
      <!-- 圆形播放按钮 -->
      <view class="play-circle {{isPlaying ? 'playing' : ''}}" bindtap="onTogglePlay">
        <image class="play-icon" src="{{isPlaying ? '/images/icon-pause.svg' : '/images/icon-play.svg'}}"></image>
      </view>
      
      <!-- 当前音效名称 -->
      <view class="current-name">{{audioTitle}}</view>

      <!-- 总音量滑块 -->
      <view class="vol-box">
        <view class="vol-label">总音量 {{masterVolume}}%</view>
        <slider 
          class="vol-slider" 
          min="0" 
          max="100" 
          value="{{masterVolume}}" 
          activeColor="#689e84" 
          backgroundColor="#d9e2e8" 
          block-size="16"
          bindchange="onVolumeChange"
        />
      </view>

      <!-- 混音列表 -->
      <view class="mix-list">
        <block wx:if="{{mixList.length === 0}}">
          <view class="mix-empty-tip">点击上方场景卡片选择音效</view>
        </block>
        <block wx:else>
          <view class="mix-item" wx:for="{{mixList}}" wx:key="id">
            <view class="mix-name">
              <text>{{item.icon}} {{item.name}}</text>
            </view>
            <slider 
              class="mix-slider" 
              min="0" 
              max="100" 
              value="{{item.volume}}" 
              activeColor="#689e84" 
              backgroundColor="#d9e2e8" 
              block-size="14"
              data-id="{{item.id}}"
              bindchange="onMixVolumeChange"
            />
          </view>
        </block>
      </view>

      <!-- 功能按钮行 -->
      <view class="func-row">
        <view class="func-item {{timerMinutes > 0 ? 'active' : ''}}" bindtap="onTimerTap">
          <text class="func-icon">⏰</text>
          <text class="func-label">定时</text>
          <text wx:if="{{timerMinutes > 0}}" class="func-badge">{{timerMinutes}}分</text>
        </view>
        <view class="func-item {{isRandom ? 'active' : ''}}" bindtap="onRandomSoundTap">
          <text class="func-icon">🎲</text>
          <text class="func-label">随机声音</text>
        </view>
        <view class="func-item {{isFavorited ? 'active' : ''}}" bindtap="onFavoriteMixTap">
          <text class="func-icon">📦</text>
          <text class="func-label">收藏声音</text>
        </view>
        <view class="func-item {{isFading ? 'active' : ''}}" bindtap="onFadeOutTap">
          <text class="func-icon">🌙</text>
          <text class="func-label">渐弱关闭</text>
          <text wx:if="{{isFading}}" class="func-badge">{{fadePercent}}%</text>
        </view>
      </view>
    </view>

    <!-- 悬浮导航占位 -->
    <view class="tab-bar-placeholder"></view>
  </view>
</view>
