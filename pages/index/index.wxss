/* 首页样式 */
.page-container {
  position: relative;
  min-height: 100vh;
  overflow-x: hidden;
}

/* 场景横滑 */
.scene-scroll {
  margin-bottom: 40rpx;
  white-space: nowrap;
}

.scene-list {
  display: flex;
  gap: 24rpx;
  padding: 12rpx 0;
}

.scene-card {
  flex-shrink: 0;
  width: 460rpx;
  height: 300rpx;
  border-radius: 32rpx;
  position: relative;
  overflow: hidden;
  box-shadow: 0 6rpx 28rpx rgba(0, 0, 0, 0.15);
}

.scene-card.active {
  box-shadow: 0 6rpx 32rpx rgba(104, 158, 132, 0.5);
  border: 4rpx solid #689e84;
}

.scene-img {
  width: 100%;
  height: 100%;
}

.scene-mask {
  position: absolute;
  left: 0;
  bottom: 0;
  width: 100%;
  padding: 32rpx;
  background: linear-gradient(transparent, rgba(0, 0, 0, 0.55));
  color: #fff;
}

.scene-title {
  font-size: 34rpx;
  margin-bottom: 6rpx;
  font-weight: 500;
}

.scene-desc {
  font-size: 24rpx;
  opacity: 0.9;
}

/* 播放器面板 */
.player-wrap {
  background: #ffffff;
  border-radius: 40rpx;
  padding: 48rpx 36rpx;
  text-align: center;
  box-shadow: 0 8rpx 28rpx rgba(0, 0, 0, 0.08);
}

/* 圆形播放按钮 */
.play-circle {
  width: 280rpx;
  height: 280rpx;
  margin: 0 auto 36rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #94bfa8, #7db396);
  display: flex;
  align-items: center;
  justify-content: center;
  animation: breathe 4.5s ease-in-out infinite alternate;
  box-shadow: 0 8rpx 32rpx rgba(104, 158, 132, 0.4);
}

.play-circle.playing {
  animation: breathe-playing 3s ease-in-out infinite alternate;
  background: linear-gradient(135deg, #7db396, #689e84);
}

@keyframes breathe {
  0% { transform: scale(0.95); }
  100% { transform: scale(1.04); }
}

@keyframes breathe-playing {
  0% { transform: scale(0.98); }
  100% { transform: scale(1.06); }
}

.play-icon {
  width: 72rpx;
  height: 72rpx;
}

.current-name {
  font-size: 28rpx;
  color: #444;
  margin-bottom: 36rpx;
}

/* 音量滑块 */
.vol-box {
  text-align: left;
  margin-bottom: 36rpx;
  padding: 0 8rpx;
}

.vol-label {
  font-size: 26rpx;
  color: #444;
  margin-bottom: 16rpx;
}

.vol-slider {
  margin: 0;
}

/* 混音列表 */
.mix-list {
  text-align: left;
  margin-bottom: 36rpx;
  min-height: 84rpx;
}

.mix-empty-tip {
  text-align: center;
  color: #999;
  font-size: 26rpx;
  padding: 20rpx 0;
}

.mix-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 0;
  border-bottom: 2rpx solid rgba(0, 0, 0, 0.06);
}

.mix-name {
  font-size: 28rpx;
  flex-shrink: 0;
  margin-right: 20rpx;
}

.mix-slider {
  width: 200rpx;
}

/* 功能行 */
.func-row {
  display: flex;
  justify-content: space-between;
  margin-bottom: 48rpx;
  padding: 0 8rpx;
  gap: 8rpx;
}

.func-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
  font-size: 22rpx;
  color: #666;
  padding: 12rpx 6rpx;
  border-radius: 16rpx;
  transition: all 0.3s;
  flex: 1;
  min-width: 0;
  text-align: center;
  position: relative;
}

.func-icon {
  font-size: 40rpx;
}

.func-label {
  font-size: 22rpx;
  color: #666;
  white-space: nowrap;
}

.func-badge {
  position: absolute;
  top: 4rpx;
  right: 12rpx;
  font-size: 18rpx;
  color: #fff;
  background: #689e84;
  padding: 2rpx 10rpx;
  border-radius: 16rpx;
  line-height: 1.2;
}

.func-item.active {
  color: #689e84;
  background: rgba(104, 158, 132, 0.1);
}

.func-item.active .func-label {
  color: #689e84;
}

/* 主按钮 */
.main-btn {
  width: 80%;
  max-width: 480rpx;
  min-width: 360rpx;
  height: 100rpx;
  border-radius: 100rpx;
  border: none;
  background: linear-gradient(135deg, #7db396, #689e84);
  color: #fff;
  font-size: 30rpx;
  font-weight: 500;
  line-height: 100rpx;
  text-align: center;
  box-shadow: 0 6rpx 20rpx rgba(104, 158, 132, 0.35);
}

.main-btn::after {
  border: none;
}
