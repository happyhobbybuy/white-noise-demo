/* 我的页面样式 */
.page-container {
  position: relative;
  min-height: 100vh;
  overflow-x: hidden;
}

.container {
  padding: 0 32rpx;
  padding-bottom: 0;
  position: relative;
}

.top-bar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
}

.page-title {
  position: absolute;
  left: 0;
  right: 0;
  text-align: center;
  font-size: 40rpx;
  font-weight: 600;
  color: #2c3840;
  white-space: nowrap;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

/* 用户信息区 */
.user-section {
  display: flex;
  align-items: center;
  padding: 32rpx;
  background: #ffffff;
  border-radius: 24rpx;
  margin-bottom: 32rpx;
}

.avatar-wrap {
  margin-right: 28rpx;
}

.avatar-default {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #94bfa8, #689e84);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 16rpx rgba(104, 158, 132, 0.3);
}

.avatar-icon {
  font-size: 56rpx;
}

.user-info {
  flex: 1;
  min-width: 0;
  overflow: hidden;
}

.user-name {
  font-size: 34rpx;
  font-weight: 600;
  color: #2c3840;
  margin-bottom: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.user-stats {
  font-size: 24rpx;
  color: #689e84;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 今日数据 */
.today-stats {
  display: flex;
  gap: 16rpx;
  margin-bottom: 32rpx;
}

.stat-card {
  flex: 1;
  background: #ffffff;
  border-radius: 20rpx;
  padding: 24rpx 16rpx;
  text-align: center;
}

.stat-value {
  font-size: 40rpx;
  font-weight: 600;
  color: #689e84;
}

.stat-label {
  font-size: 20rpx;
  color: #999;
  margin-top: 8rpx;
}

/* 菜单列表 */
.menu-section {
  margin-bottom: 32rpx;
}

.menu-group {
  background: #ffffff;
  border-radius: 20rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 28rpx 32rpx;
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.04);
  background: transparent;
  text-align: left;
  font-size: inherit;
  line-height: inherit;
  margin: 0;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-item::after {
  border: none;
}

.feedback-btn,
.share-btn {
  width: 100%;
  border: none;
  background: transparent;
  color: inherit;
  font-size: inherit;
  padding: 28rpx 32rpx;
  text-align: left;
  display: flex;
  align-items: center;
  line-height: normal;
  margin: 0;
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.04);
}

.feedback-btn::after,
.share-btn::after {
  border: none;
}

.menu-icon {
  font-size: 36rpx;
  margin-right: 20rpx;
}

.menu-text {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}

.menu-badge {
  background: #689e84;
  color: #fff;
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 16rpx;
  margin-right: 12rpx;
}

.menu-arrow {
  font-size: 32rpx;
  color: #ccc;
}


/* 弹窗 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.4);
  z-index: 1000;
  display: flex;
  align-items: flex-end;
}

.modal-content {
  width: 100%;
  max-height: 80vh;
  background: #fff;
  border-radius: 32rpx 32rpx 0 0;
  overflow: hidden;
  display: flex;
  flex-direction: column;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 32rpx;
  border-bottom: 1rpx solid #f0f0f0;
  flex-shrink: 0;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.modal-close {
  font-size: 36rpx;
  color: #999;
  padding: 8rpx;
}

.modal-body {
  padding: 24rpx 32rpx;
  flex: 1;
  min-height: 0;
  box-sizing: border-box;
}

.modal-empty {
  text-align: center;
  padding: 60rpx 0;
  color: #999;
  font-size: 28rpx;
}

/* 混音方案卡片 */
.mix-card {
  background: #f8f9fa;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.mix-card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
  gap: 16rpx;
}

.mix-card-name {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
  flex: 1;
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.mix-card-time {
  font-size: 22rpx;
  color: #999;
  flex-shrink: 0;
  max-width: 50%;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.mix-card-items {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.mix-card-item {
  font-size: 24rpx;
  color: #666;
  background: #fff;
  padding: 6rpx 16rpx;
  border-radius: 12rpx;
  max-width: 100%;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.mix-card-actions {
  display: flex;
  gap: 16rpx;
}

.mix-action-btn {
  padding: 12rpx 28rpx;
  border-radius: 16rpx;
  font-size: 24rpx;
  text-align: center;
  min-width: 120rpx;
}

.mix-action-btn.load {
  background: #689e84;
  color: #fff;
}

.mix-action-btn.delete {
  background: #f0f0f0;
  color: #666;
}

/* 统计弹窗 */
.stats-summary {
  display: flex;
  gap: 20rpx;
  margin-bottom: 32rpx;
}

.summary-item {
  flex: 1;
  text-align: center;
  background: #f8f9fa;
  border-radius: 16rpx;
  padding: 24rpx 12rpx;
}

.summary-value {
  font-size: 40rpx;
  font-weight: 600;
  color: #689e84;
}

.summary-label {
  font-size: 22rpx;
  color: #999;
  margin-top: 8rpx;
}

.chart-title {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
  margin-bottom: 24rpx;
}

.bar-chart {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  height: 280rpx;
  padding: 0 10rpx;
}

.bar-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 60rpx;
  flex: 1;
  min-width: 0;
  max-width: 80rpx;
}

.bar-fill {
  width: 36rpx;
  background: linear-gradient(180deg, #689e84, #94bfa8);
  border-radius: 8rpx 8rpx 0 0;
  min-height: 8rpx;
  margin-bottom: 8rpx;
  transition: height 0.3s;
}

.bar-value {
  font-size: 20rpx;
  color: #666;
  margin-bottom: 4rpx;
}

.bar-label {
  font-size: 20rpx;
  color: #999;
}
