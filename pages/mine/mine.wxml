<view class="page-container">
  <view class="base-bg"></view>
  <!-- 播放时全屏实景背景 -->
  <image class="play-bg {{bgUrl ? 'active' : ''}}" src="{{bgUrl}}" mode="aspectFill"></image>
  <!-- 毛玻璃遮罩层 -->
  <view class="blur-overlay {{bgUrl ? 'active' : ''}}"></view>

  <view class="top-bar" style="position: fixed; top: 0; left: 0; right: 0; z-index: 100; height: {{menuButtonTop + menuButtonHeight}}px;">
    <view class="page-title" style="padding-top: {{menuButtonTop}}px; height: {{menuButtonHeight}}px;">我的</view>
  </view>

  <view class="container" style="padding-top: {{menuButtonTop + menuButtonHeight + 10}}px;">
    <!-- 用户信息区 -->
    <view class="user-section">
      <view class="avatar-wrap">
        <view class="avatar-default">
          <text class="avatar-icon">🎧</text>
        </view>
      </view>
      <view class="user-info">
        <view class="user-name">白噪音用户</view>
        <view class="user-stats">累计专注 {{totalFocusMinutes}} 分钟</view>
      </view>
    </view>

    <!-- 今日数据 -->
    <view class="today-stats">
      <view class="stat-card">
        <view class="stat-value">{{todayMinutes}}</view>
        <view class="stat-label">今日专注(分钟)</view>
      </view>
      <view class="stat-card">
        <view class="stat-value">{{todayRounds}}</view>
        <view class="stat-label">今日完成(轮)</view>
      </view>
      <view class="stat-card">
        <view class="stat-value">{{savedMixCount}}</view>
        <view class="stat-label">收藏方案</view>
      </view>
    </view>

    <!-- 功能列表 -->
    <view class="menu-section">
      <view class="menu-group">
        <view class="menu-item" bindtap="onMyMixesTap">
          <text class="menu-icon">🎵</text>
          <text class="menu-text">我的混音方案</text>
          <text class="menu-badge" wx:if="{{savedMixCount > 0}}">{{savedMixCount}}</text>
          <text class="menu-arrow">›</text>
        </view>
        <view class="menu-item" bindtap="onFavoritesTap">
          <text class="menu-icon">⭐</text>
          <text class="menu-text">我的收藏</text>
          <text class="menu-arrow">›</text>
        </view>
        <view class="menu-item" bindtap="onStatsTap">
          <text class="menu-icon">📊</text>
          <text class="menu-text">专注统计</text>
          <text class="menu-arrow">›</text>
        </view>
      </view>

      <view class="menu-group">
        <view class="menu-item" bindtap="onPlaySettingTap">
          <text class="menu-icon">🎧</text>
          <text class="menu-text">播放设置</text>
          <text class="menu-arrow">›</text>
        </view>
        <view class="menu-item" bindtap="onReminderTap">
          <text class="menu-icon">🔔</text>
          <text class="menu-text">提醒设置</text>
          <text class="menu-arrow">›</text>
        </view>

      </view>

      <view class="menu-group">
        <view class="menu-item" bindtap="onAboutTap">
          <text class="menu-icon">📱</text>
          <text class="menu-text">关于</text>
          <text class="menu-arrow">›</text>
        </view>
        <button class="menu-item feedback-btn" open-type="feedback">
          <text class="menu-icon">💬</text>
          <text class="menu-text">反馈建议</text>
          <text class="menu-arrow">›</text>
        </button>
        <button class="menu-item share-btn" open-type="share">
          <text class="menu-icon">📤</text>
          <text class="menu-text">分享给好友</text>
          <text class="menu-arrow">›</text>
        </button>
      </view>
    </view>

    <!-- 混音方案弹窗 -->
    <view class="modal-mask" wx:if="{{showMixModal}}" bindtap="closeMixModal">
      <view class="modal-content" catchtap="">
        <view class="modal-header">
          <text class="modal-title">我的混音方案</text>
          <text class="modal-close" bindtap="closeMixModal">✕</text>
        </view>
        <scroll-view class="modal-body" scroll-y="true">
          <view wx:if="{{savedMixes.length === 0}}" class="modal-empty">
            <text>暂无保存的混音方案</text>
          </view>
          <view class="mix-card" wx:for="{{savedMixes}}" wx:key="id">
            <view class="mix-card-header">
              <text class="mix-card-name">{{item.name}}</text>
              <text class="mix-card-time">{{item.createTime}}</text>
            </view>
            <view class="mix-card-items">
              <text class="mix-card-item" wx:for="{{item.items}}" wx:for-item="mix" wx:key="id">
                {{mix.icon}} {{mix.name}}
              </text>
            </view>
            <view class="mix-card-actions">
              <view class="mix-action-btn load" data-index="{{index}}" bindtap="onLoadMix">加载播放</view>
              <view class="mix-action-btn delete" data-index="{{index}}" bindtap="onDeleteMix">删除</view>
            </view>
          </view>
        </scroll-view>
      </view>
    </view>

    <!-- 专注统计弹窗 -->
    <view class="modal-mask" wx:if="{{showStatsModal}}" bindtap="closeStatsModal">
      <view class="modal-content" catchtap="">
        <view class="modal-header">
          <text class="modal-title">专注统计</text>
          <text class="modal-close" bindtap="closeStatsModal">✕</text>
        </view>
        <scroll-view class="modal-body" scroll-y="true">
          <view class="stats-summary">
            <view class="summary-item">
              <view class="summary-value">{{weekTotalMinutes}}</view>
              <view class="summary-label">本周(分钟)</view>
            </view>
            <view class="summary-item">
              <view class="summary-value">{{monthTotalMinutes}}</view>
              <view class="summary-label">本月(分钟)</view>
            </view>
            <view class="summary-item">
              <view class="summary-value">{{totalFocusMinutes}}</view>
              <view class="summary-label">总计(分钟)</view>
            </view>
          </view>
          
          <!-- 简易柱状图 -->
          <view class="chart-title">近7天专注时长</view>
          <view class="bar-chart">
            <view class="bar-item" wx:for="{{weekData}}" wx:key="date">
              <view class="bar-fill" style="height: {{item.percent}}%;"></view>
              <view class="bar-value">{{item.minutes}}</view>
              <view class="bar-label">{{item.label}}</view>
            </view>
          </view>
        </scroll-view>
      </view>
    </view>

    <!-- 悬浮导航占位 -->
    <view class="tab-bar-placeholder"></view>
  </view>
</view>
